// Тест: Автоматическое формирование понятий (MDL)
// [!] ВАЖНО: Объект (имя) стоит на ПЕРВОМ месте!
факт симптом(иван, кашель) = да причина факт.
факт симптом(мария, кашель) = да причина факт.
факт симптом(петр, кашель) = да причина факт.

факт температура(иван) = да причина факт.
факт температура(мария) = да причина факт.
факт температура(петр) = да причина факт.

факт вирус(иван) = да причина факт.
факт вирус(мария) = да причина факт.
факт вирус(петр) = да причина факт.

// Новый объект, у которого есть симптомы, но нет диагноза
факт симптом(олег, кашель) = да причина факт.
факт температура(олег) = да причина факт.

цель: вирус(олег) = Статус причина Отчет.
